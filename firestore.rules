rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /uploads/{docId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasOnly(['color', 'url', 'day', 'createdAt'])
                    && request.resource.data.color in ['yellow', 'green', 'blue']
                    && request.resource.data.url is string
                    && request.resource.data.day is string;
      // No real auth in this app (see README), so this can't verify *which*
      // account is deleting — only the client UI restricts delete buttons
      // to a user's own photos.
      // Likes work the same way, except "can't like your own photo" *is*
      // enforced here: the doc's own color can never appear in its own
      // likes list, which holds regardless of which account calls update.
      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes'])
                    && request.resource.data.likes is list
                    && request.resource.data.likes.size() <= 3
                    && request.resource.data.likes.hasOnly(['yellow', 'green', 'blue'])
                    && !(resource.data.color in request.resource.data.likes);
      allow delete: if true;
    }

    // Tracks the one like each account may give out per calendar day, as
    // { day: "YYYY-MM-DD", photoId }. Same trust model as uploads above:
    // no real auth, so this only validates shape, not which account is
    // writing its own doc.
    match /likeLimits/{account} {
      allow read: if true;
      allow create, update: if account in ['yellow', 'green', 'blue']
                            && request.resource.data.keys().hasOnly(['day', 'photoId'])
                            && request.resource.data.day is string
                            && request.resource.data.photoId is string;
      allow delete: if true;
    }
  }
}
